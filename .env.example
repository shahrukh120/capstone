# ── Required API Keys ─────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# ── Database ──────────────────────────────────────────
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/ats_db

# ── LLM Configuration ────────────────────────────────
# Provider: "groq", "nvidia", or "ollama"
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ── Ollama (local only, not available in Docker on AWS) ─
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:12b

# ── Embeddings ────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── SMTP Email (for candidate emails + interview invites) ─
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASSWORD=<api-key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=AI-ATS Recruiter <your@gmail.com>
SMTP_USE_TLS=true
